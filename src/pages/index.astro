    .brand h1 { font-size: 16px; margin: 0; color: #fff; font-weight: 700; letter-spacing: .2px; }
    .brand span { color: #7fa3bd; font-size: 12.5px; margin-left: 2px; }
    .tabs { display: flex; gap: 6px; overflow: visible; padding-bottom: 10px; align-items: center; }
    .details-wrap { position: relative; }
    .menu {
      position: absolute; top: calc(100% + 6px); left: 0; background: #fff;
      border: 1px solid var(--line); border-radius: 12px; box-shadow: 0 12px 34px rgba(10,25,40,.24);
      padding: 6px; min-width: 260px; max-height: 72vh; overflow-y: auto; display: none; z-index: 60;
    }
    .menu.open { display: block; }
    .menu-item {
      display: flex; align-items: center; gap: 9px; width: 100%; text-align: left;
      background: transparent; border: none; border-radius: 8px; padding: 9px 12px;
      font-size: 14px; color: var(--ink); cursor: pointer;
    }
    .menu-item:hover { background: #f1f6fb; }
    .menu-item.active { background: var(--accent); color: #fff; }
    .menu-item .rk { opacity: .55; font-variant-numeric: tabular-nums; min-width: 18px; }
    .menu-item.active .rk { opacity: .85; }
    .burger { font-size: 15px; line-height: 1; margin-right: 2px; }
    #det-label { opacity: .9; font-weight: 600; }
    .navbtn {
      flex: 0 0 auto; background: rgba(255,255,255,.08); color: var(--nav-ink);
      border: 1px solid rgba(255,255,255,.28); border-radius: 999px; padding: 6px 13px;
      font-size: 13px; cursor: pointer; white-space: nowrap; transition: all .15s;
    }
    .navbtn:hover { background: rgba(255,255,255,.2); color: #fff; }
    .navbtn.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 600; }
    /* ---- Layout ---- */
    main { max-width: 1080px; margin: 0 auto; padding: 26px 16px 60px; }
    .loc-section { display: none; animation: fade .25s ease; }
    .loc-section.active { display: block; }
    @keyframes fade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
    /* ---- Hero ---- */
    .hero {
      border-radius: 16px; padding: 26px 26px 24px; color: #fff; position: relative;
      overflow: hidden; box-shadow: var(--shadow);
      background: linear-gradient(135deg, #0a4d6e 0%, #1f8bb5 55%, #5ec8e0 100%);
    }
    .hero::after {
      content: ""; position: absolute; right: -40px; bottom: -60px; width: 260px; height: 260px;
      background: radial-gradient(circle, rgba(255,255,255,.14), transparent 70%);
    }
    .hero .rank-badge {
      display: inline-block; background: rgba(255,255,255,.16); border: 1px solid rgba(255,255,255,.3);
      border-radius: 999px; padding: 3px 12px; font-size: 12.5px; font-weight: 600; margin-bottom: 12px;
    }
    .hero h2 { margin: 0 0 4px; font-size: 30px; letter-spacing: -.5px; }
    .hero .region { font-size: 14px; opacity: .9; margin-bottom: 14px; }
    .hero .tagline { font-size: 15px; max-width: 680px; opacity: .96; position: relative; z-index: 1; }
    .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; position: relative; z-index: 1; }
    .chip { background: rgba(255,255,255,.14); border: 1px solid rgba(255,255,255,.22); border-radius: 10px; padding: 7px 12px; font-size: 12.5px; }
    .chip b { display: block; font-size: 11px; font-weight: 600; opacity: .8; margin-bottom: 1px; text-transform: uppercase; letter-spacing: .4px; }
    /* ---- Sektionstitel ---- */
    .sec-title { font-size: 14px; text-transform: uppercase; letter-spacing: .8px; color: var(--muted); margin: 30px 2px 14px; font-weight: 700; }
    /* ---- Preis-Karten ---- */
    .price-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; }
    .pcard { background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 18px 18px 16px; box-shadow: var(--shadow); position: relative; }
    .pcard.ai { border-top: 4px solid var(--ai); }
    .pcard.sv { border-top: 4px solid var(--sv); }
    .pcard .ptype { font-size: 12px; text-transform: uppercase; letter-spacing: .5px; color: var(--muted); font-weight: 700; }
    .pcard .pbig { font-size: 32px; font-weight: 800; letter-spacing: -1px; margin: 4px 0 2px; font-variant-numeric: tabular-nums; }
    .pcard.ai .pbig { color: var(--ai); }
    .pcard.sv .pbig { color: var(--sv); }
    .pcard .punit { font-size: 12.5px; color: var(--muted); }
    .pcard .pdesc { font-size: 13px; color: #34495a; margin-top: 10px; line-height: 1.45; }
    .pcard .pp { font-size: 12px; color: var(--muted); margin-top: 8px; font-variant-numeric: tabular-nums; }
    .pricehint { font-size: 13px; color: #34495a; background: #f1f6fb; border-radius: 10px; padding: 12px 14px; margin-top: 14px; }
    /* ---- Wetter ---- */
    .weather-wrap { display: grid; grid-template-columns: 1.2fr 1fr; gap: 18px; align-items: stretch; }
    .wcard { background: var(--card); border: 1px solid var(--line); border-radius: 14px; padding: 16px; box-shadow: var(--shadow); }
    svg.weather { width: 100%; height: auto; display: block; }
    svg.weather .grid { stroke: #eef2f6; stroke-width: 1; }
    svg.weather .ax { fill: #93a3b2; font-size: 10.5px; font-family: inherit; }
    svg.weather .rlbl { fill: var(--muted); font-size: 12.5px; font-weight: 600; font-family: inherit; }
    svg.weather .val { fill: var(--ink); font-size: 12.5px; font-weight: 700; font-family: inherit; }
    .wstats { display: flex; flex-direction: column; gap: 10px; justify-content: center; }
    .wstat { display: flex; align-items: center; gap: 12px; }
    .wstat .ic { font-size: 22px; width: 30px; text-align: center; }
    .wstat b { font-size: 18px; font-variant-numeric: tabular-nums; }
    .wstat span { color: var(--muted); font-size: 12.5px; }
    .wnote { font-size: 13px; color: #34495a; background: #f1f6fb; border-radius: 10px; padding: 12px 14px; margin-top: 14px; }
    /* ---- Highlights ---- */
    .hl { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
    .hl li { background: var(--card); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; font-size: 14px; color: #34495a; display: flex; gap: 10px; box-shadow: var(--shadow); }
    .hl li::before { content: "›"; color: var(--accent); font-weight: 800; }
    /* ---- Konkrete Angebote ---- */
    table.offers { width: 100%; border-collapse: collapse; font-size: 13.5px; background: var(--card); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow); }
    table.offers th, table.offers td { padding: 10px 12px; text-align: left; border-bottom: 1px solid var(--line); vertical-align: middle; }
    table.offers th { background: #eef3f8; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; color: var(--muted); font-weight: 700; }
    table.offers tr:last-child td { border-bottom: none; }
    table.offers tbody tr:hover { background: #f3f8fc; }
    table.offers .stars { color: #f4a23a; font-size: 11px; letter-spacing: -1px; white-space: nowrap; }
    table.offers .rbadge { display: inline-block; background: var(--accent); color: #fff; font-weight: 700; font-size: 12px; border-radius: 6px; padding: 1px 6px; font-variant-numeric: tabular-nums; }
    table.offers .rev { color: var(--muted); font-size: 12px; }
    table.offers .oprice { font-weight: 800; color: var(--accent); font-variant-numeric: tabular-nums; white-space: nowrap; }
    .offernote { font-size: 12px; color: var(--muted); background: #f1f6fb; border-radius: 10px; padding: 12px 14px; margin-top: 12px; line-height: 1.5; }
    .offernote a { color: var(--accent2); font-weight: 600; text-decoration: none; }
    .offernote a:hover { text-decoration: underline; }
    .hotelmap { width: 100%; height: 340px; position: relative; z-index: 0; border-radius: 14px; border: 1px solid var(--line); box-shadow: var(--shadow); margin-bottom: 8px; background: #e8eef4; }
    .maphint { font-size: 11.5px; color: var(--muted); margin: 0 2px 14px; }
    table.offers .hotellink { color: var(--ink); text-decoration: none; }
    table.offers .hotellink:hover { color: var(--accent); text-decoration: underline; }
    .leaflet-popup-content { font-family: inherit; font-size: 13px; }
    .leaflet-popup-content a { color: var(--accent2); font-weight: 600; }
    /* ---- Übersicht ---- */
    .intro { font-size: 15.5px; color: #34495a; max-width: 740px; }
    table.rank { width: 100%; border-collapse: collapse; margin-top: 16px; font-size: 13.5px; background: var(--card); border-radius: 12px; overflow: hidden; box-shadow: var(--shadow); }
    table.rank th, table.rank td { padding: 10px 12px; text-align: left; border-bottom: 1px solid var(--line); }
    table.rank th { background: #eef3f8; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; color: var(--muted); }
    table.rank tr:last-child td { border-bottom: none; }
    table.rank tr { cursor: pointer; transition: background .12s; }
    table.rank tbody tr:hover { background: #f3f8fc; }
    table.rank td.r { font-weight: 700; color: var(--accent); }
    table.rank td.price { font-variant-numeric: tabular-nums; font-weight: 600; }
    .barchart { margin-top: 26px; }
    .metric-btns { display: flex; flex-wrap: wrap; gap: 6px; margin: 4px 0 6px; }
    .mbtn { background: var(--card); border: 1px solid var(--line); color: #34495a; border-radius: 999px; padding: 6px 13px; font-size: 12.5px; cursor: pointer; transition: all .15s; }
    .mbtn:hover { border-color: var(--accent2); color: var(--accent2); }
    .mbtn.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 600; }
    .metric-hint { font-size: 12.5px; color: var(--muted); margin: 0 2px 14px; min-height: 16px; }
    .bar-row { display: grid; grid-template-columns: 150px 1fr 92px; align-items: center; gap: 10px; margin-bottom: 8px; }
    .bar-row .lbl { font-size: 13px; text-align: right; color: #34495a; }
    .bar-track { background: #e8eef4; border-radius: 6px; height: 18px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 6px; background: linear-gradient(90deg, #0e8fc0, #5ec8e0); }
    .bar-row .val { font-size: 12.5px; font-variant-numeric: tabular-nums; color: var(--muted); }
    .callouts { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap: 14px; margin-top: 24px; }
    .callout { background: var(--card); border: 1px solid var(--line); border-left: 4px solid var(--accent); border-radius: 10px; padding: 14px 16px; box-shadow: var(--shadow); }
    .callout b { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; color: var(--accent); margin-bottom: 4px; }
    .callout span { font-size: 14px; color: #34495a; }
    footer { max-width: 1080px; margin: 0 auto; padding: 0 16px 50px; color: var(--muted); font-size: 12.5px; }
    footer hr { border: none; border-top: 1px solid var(--line); margin: 0 0 16px; }
    @media (max-width: 640px) {
      .hero h2 { font-size: 24px; }
      .weather-wrap { grid-template-columns: 1fr; }
      .bar-row { grid-template-columns: 104px 1fr 84px; }
      .bar-row .lbl { font-size: 12px; }
    }
  </style>
</head>
<body>
  <header class="nav">
    <div class="nav-inner">
      <div class="brand">
        <span class="mark">🏖️</span>
        <h1>Herbstferien-Urlaub <span>· Familienziele im Vergleich</span></h1>
      </div>
      <nav class="tabs" id="tabs">
        <button class="navbtn active" id="nav-overview" onclick="showOverview()">Übersicht</button>
        <div class="details-wrap">
          <button class="navbtn" id="nav-details" onclick="toggleMenu(event)" aria-haspopup="true"><span class="burger">☰</span> Ziele<span id="det-label"></span></button>
          <div class="menu" id="region-menu" role="menu">
            {destinations.map((d) => (
              <button class="menu-item" data-id={d.id} data-name={d.name} onclick={`selectRegion('${d.id}')`} role="menuitem">
                <span class="rk">{d.rank}</span>{d.flag} {d.name}
              </button>
            ))}
          </div>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <!-- Übersicht -->
    <section class="loc-section active" id="sec-overview">
      <div class="hero" style="background: linear-gradient(135deg,#0a4d6e 0%,#2bb3c4 120%);">
        <span class="rank-badge">Berliner Herbstferien · 19.–31. Oktober 2026</span>
        <h2>Wohin in den Herbstferien?</h2>
        <div class="region">7 Nächte · 2 Erwachsene + Kind (8 J.) + Kind (5 J.) · Flug ab Berlin (BER)</div>
        <p class="tagline">Sechs sonnensichere Familienziele im direkten Vergleich — Gesamtpreis für die Familie als All-Inclusive und als Selbstverpfleger (nur Flug + Unterkunft), dazu das erwartbare Wetter im Oktober. Oben in der Leiste durch die Ziele schalten oder in der Tabelle ein Ziel anklicken.</p>
      </div>

      <div class="sec-title">Ranking &amp; Preisüberblick</div>
      <table class="rank">
        <thead>
          <tr><th>#</th><th>Ziel</th><th>Region</th><th>All&nbsp;Incl.</th><th>Selbstverpfl.</th><th>Wetter (Luft/Wasser)</th></tr>
        </thead>
        <tbody>
          {destinations.map((d) => (
            <tr onclick={`showLoc('${d.id}')`}>
              <td class="r">{d.rank}</td>
              <td><b>{d.flag} {d.name}</b></td>
              <td>{d.region}</td>
              <td class="price">{eur(d.priceAI)}</td>
              <td class="price">{eur(d.priceSV)}</td>
              <td>{d.airTemp}° / {d.waterTemp}°</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="sec-title">Ziele vergleichen</div>
      <div class="metric-btns" id="metric-btns">
        <button class="mbtn active" data-metric="priceAI">Preis All-Inclusive</button>
        <button class="mbtn" data-metric="priceSV">Preis Selbstverpfleger</button>
        <button class="mbtn" data-metric="airTemp">Lufttemperatur</button>
        <button class="mbtn" data-metric="waterTemp">Wassertemperatur</button>
        <button class="mbtn" data-metric="sunHours">Sonnenstunden</button>
        <button class="mbtn" data-metric="rainDays">Regentage</button>
        <button class="mbtn" data-metric="flightTime">Flugzeit</button>
      </div>
      <div class="metric-hint" id="metric-hint"></div>
      <div class="barchart" id="barchart"></div>

      <div class="callouts">
        <div class="callout"><b>Günstigste Familie</b><span>Djerba &gt; Albanien &gt; Mallorca</span></div>
        <div class="callout"><b>Wärmstes Wetter</b><span>Ägypten (29°/26°), dann Zypern</span></div>
        <div class="callout"><b>Kürzester Flug</b><span>Kroatien (1,75 h) &amp; Mallorca (2,5 h)</span></div>
        <div class="callout"><b>Wärmstes Meer</b><span>Ägypten (26°) &amp; Zypern (25°)</span></div>
      </div>
    </section>

    <!-- Ziele -->
    {destinations.map((d) => (
      <section class="loc-section" id={`sec-${d.id}`}>
        <div class="hero">
          <span class="rank-badge">Rang {d.rank} · {d.character}</span>
          <h2>{d.flag} {d.name}</h2>
          <div class="region">{d.region}</div>
          <p class="tagline">{d.tagline}</p>
          <div class="chips">
            <div class="chip"><b>All-Inclusive</b>{eur(d.priceAI)} / Familie</div>
            <div class="chip"><b>Selbstverpfleger</b>{eur(d.priceSV)} / Familie</div>
            <div class="chip"><b>Flug ab Berlin</b>{d.airport} · {('' + d.flightTime).replace('.', ',')} h</div>
            <div class="chip"><b>Wetter Okt.</b>{d.airTemp}° Luft · {d.waterTemp}° Wasser</div>
          </div>
        </div>

        <div class="sec-title">Preis für 7 Nächte · ganze Familie inkl. Flug</div>
        <div class="price-grid">
          <div class="pcard ai">
            <div class="ptype">All-Inclusive</div>
            <div class="pbig">{eur(d.priceAI)}</div>
            <div class="punit">für 2 Erw. + 2 Kinder · inkl. Flug & Verpflegung</div>
            <div class="pp">entspricht ~{fmt(Math.round(d.priceAI / 7))} € pro Nacht</div>
          </div>
          <div class="pcard sv">
            <div class="ptype">Selbstverpfleger</div>
            <div class="pbig">{eur(d.priceSV)}</div>
            <div class="punit">nur Flug + Unterkunft · Verpflegung selbst</div>
            <div class="pp">entspricht ~{fmt(Math.round(d.priceSV / 7))} € pro Nacht · Ersparnis ~{eur(d.priceAI - d.priceSV)}</div>
          </div>
        </div>
        <div class="pricehint">{d.priceNote}</div>

        <div class="sec-title">Erwartbares Wetter · zweite Oktoberhälfte</div>
        <div class="weather-wrap">
          <div class="wcard"><Fragment set:html={weatherSVG(d)} /></div>
          <div class="wcard wstats">
            <div class="wstat"><span class="ic">🌡️</span><div><b>{d.airTemp} °C</b> <span>Luft tagsüber</span></div></div>
            <div class="wstat"><span class="ic">🌊</span><div><b>{d.waterTemp} °C</b> <span>Wassertemperatur</span></div></div>
            <div class="wstat"><span class="ic">☀️</span><div><b>{d.sunHours} h</b> <span>Sonne pro Tag</span></div></div>
            <div class="wstat"><span class="ic">🌧️</span><div><b>{d.rainDays}</b> <span>Regentage pro Woche (ca.)</span></div></div>
          </div>
        </div>
        <div class="wnote">{d.weatherNote}</div>

        <div class="sec-title">Gut für Familien</div>
        <ul class="hl">
          {d.highlights.map((h) => (<li>{h}</li>))}
        </ul>

        {d.offers && (
          <Fragment>
            <div class="sec-title">Konkrete All-Inclusive-Angebote · {d.offersMeta.date}</div>
            <script type="application/json" id={`hotels-${d.id}`} set:html={JSON.stringify(d.offers.map((o) => ({ name: o.hotel, region: o.region, price: o.price, lat: o.lat, lng: o.lng, url: o.url })))}></script>
            <table class="offers">
              <thead>
                <tr><th>Hotel</th><th>Region</th><th>Bewertung</th><th>Preis Familie<br/>inkl. Flug</th></tr>
              </thead>
              <tbody>
                {d.offers.map((o) => (
                  <tr>
                    <td><b><a class="hotellink" href={o.url} target="_blank" rel="noopener">{o.hotel} ↗</a></b> <span class="stars">★★★★★</span></td>
                    <td><a class="hotellink" href={gmaps(o.region.replace(' · ', ' ') + ' Türkei')} target="_blank" rel="noopener">{o.region} ↗</a></td>
                    <td><span class="rbadge">{o.rating}</span> {o.ratingWord} <span class="rev">{o.reviews} Bew.</span></td>
                    <td class="oprice">{eur(o.price)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            <div class="sec-title">Lage der Hotels</div>
            <div id={`map-${d.id}`} class="hotelmap"></div>
            <div class="maphint">Karte: ungefähre Lage der Hotels (Resort-Ebene). Klick auf einen Marker zeigt das Angebot bei CHECK24. Kartendaten © OpenStreetMap-Mitwirkende.</div>
            <div class="offernote">
              {d.offersMeta.note} Quelle: {d.offersMeta.source} — <a href={d.offersMeta.url} target="_blank" rel="noopener">alle Angebote ansehen ↗</a>. Jeder Hotelname (und Kartenmarker) führt direkt zum jeweiligen Hotel bei CHECK24 — gleicher Zeitraum & Familienbelegung.
            </div>
          </Fragment>
        )}
      </section>
    ))}
  </main>

  <footer>
    <hr />
    <p><b>Hinweis:</b> Preise sind realistische Richtwerte (Stand Juni 2026) für die gesamte Familie (2 Erwachsene + Kind 8 J. + Kind 5 J.), 7 Nächte inkl. Flug ab Berlin, im Reisezeitraum der Berliner Herbstferien (19.–31. Oktober 2026). „AI" = All-Inclusive, „Selbstverpfleger" = nur Flug + Unterkunft. Bei der Türkei sind zusätzlich konkrete, live recherchierte Angebote für 24.–31.10.2026 hinterlegt; die Kartenmarker zeigen die ungefähre Resort-Lage. Tatsächliche Preise hängen stark von Hotel, Buchungszeitpunkt und Verfügbarkeit ab. Wetterangaben sind langjährige Klima-Mittelwerte für die zweite Oktoberhälfte, keine Vorhersage. Keine verbindlichen Angebote — vor Buchung bitte aktuell prüfen.</p>
  </footer>

  <script type="application/json" id="chartdata" set:html={JSON.stringify(CHART)}></script>
  <script is:inline>
    function setSection(id) {
      document.querySelectorAll('.loc-section').forEach((s) => s.classList.remove('active'));
      var sec = document.getElementById('sec-' + id);
      if (sec) sec.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    function closeMenu() { var m = document.getElementById('region-menu'); if (m) m.classList.remove('open'); }
    function toggleMenu(e) { if (e) e.stopPropagation(); var m = document.getElementById('region-menu'); if (m) m.classList.toggle('open'); }
    function showOverview() {
      setSection('overview');
      document.getElementById('nav-details').classList.remove('active');
      document.getElementById('nav-overview').classList.add('active');
      var lbl = document.getElementById('det-label'); if (lbl) lbl.textContent = '';
      document.querySelectorAll('.menu-item').forEach((b) => b.classList.remove('active'));
      closeMenu();
    }
    function selectRegion(id) {
      var item = document.querySelector('.menu-item[data-id="' + id + '"]');
      setSection(id);
      document.getElementById('nav-overview').classList.remove('active');
      document.getElementById('nav-details').classList.add('active');
      var lbl = document.getElementById('det-label'); if (lbl) lbl.textContent = item ? ' · ' + item.getAttribute('data-name') : '';
      document.querySelectorAll('.menu-item').forEach((b) => b.classList.toggle('active', b.getAttribute('data-id') === id));
      closeMenu();
      if (window.__maps && window.__maps[id]) {
        setTimeout(function () { window.__maps[id].map.invalidateSize(); window.__maps[id].map.fitBounds(window.__maps[id].bounds, { padding: [30, 30] }); }, 260);
      }
    }
    function showLoc(id) { if (id === 'overview') showOverview(); else selectRegion(id); }
    document.addEventListener('click', function (e) {
      var w = document.querySelector('.details-wrap');
      if (w && !w.contains(e.target)) closeMenu();
    });
    /* --- Umschaltbares Vergleichs-Diagramm --- */
    var CHART_DATA = JSON.parse(document.getElementById('chartdata').textContent);
    function nf(n) { return n.toLocaleString('de-DE'); }
    var METRICS = {
      priceAI:   { lower: true,  hint: 'All-Inclusive-Gesamtpreis für die Familie (7 Nächte, inkl. Flug) — weniger = günstiger', fmt: function (v) { return '~' + nf(v) + ' €'; } },
      priceSV:   { lower: true,  hint: 'Selbstverpfleger: nur Flug + Unterkunft für die Familie — weniger = günstiger',          fmt: function (v) { return '~' + nf(v) + ' €'; } },
      airTemp:   { lower: false, hint: 'Durchschnittliche Lufttemperatur tagsüber in der zweiten Oktoberhälfte',                  fmt: function (v) { return v + ' °C'; } },
      waterTemp: { lower: false, hint: 'Durchschnittliche Wassertemperatur im Oktober',                                          fmt: function (v) { return v + ' °C'; } },
      sunHours:  { lower: false, hint: 'Sonnenstunden pro Tag (Richtwert Oktober)',                                              fmt: function (v) { return v + ' h'; } },
      rainDays:  { lower: true,  hint: 'Regentage pro Woche (ca.) — weniger = trockener',                                        fmt: function (v) { return v === 0 ? 'fast 0' : v + ' Tage'; } },
      flightTime:{ lower: true,  hint: 'Reine Flugzeit ab Berlin — weniger = kürzer',                                            fmt: function (v) { return ('' + v).replace('.', ',') + ' h'; } }
    };
    function renderChart(key) {
      var m = METRICS[key];
      var rows = CHART_DATA.slice().sort(function (a, b) { return m.lower ? a[key] - b[key] : b[key] - a[key]; });
      var maxv = Math.max.apply(null, CHART_DATA.map(function (d) { return d[key]; }));
      var html = rows.map(function (d) {
        var w = Math.max(4, Math.round((d[key] / maxv) * 100));
        return '<div class="bar-row"><div class="lbl">' + d.name + '</div>' +
               '<div class="bar-track"><div class="bar-fill" style="width:' + w + '%"></div></div>' +
               '<div class="val">' + m.fmt(d[key]) + '</div></div>';
      }).join('');
      document.getElementById('barchart').innerHTML = html;
      document.getElementById('metric-hint').textContent = m.hint;
      document.querySelectorAll('.mbtn').forEach(function (b) {
        b.classList.toggle('active', b.getAttribute('data-metric') === key);
      });
    }
    document.querySelectorAll('.mbtn').forEach(function (b) {
      b.addEventListener('click', function () { renderChart(b.getAttribute('data-metric')); });
    });
    renderChart('priceAI');

    /* --- Hotel-Karten (Leaflet/OpenStreetMap) --- */
    window.__maps = {};
    function initHotelMap(id) {
      var el = document.getElementById('map-' + id);
      var dataEl = document.getElementById('hotels-' + id);
      if (!el || !dataEl || typeof L === 'undefined') return;
      var data = JSON.parse(dataEl.textContent);
      if (!data.length) return;
      var map = L.map('map-' + id, { scrollWheelZoom: false });
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 18, attribution: '© OpenStreetMap' }).addTo(map);
      var pts = [];
      data.forEach(function (h) {
        L.marker([h.lat, h.lng]).addTo(map).bindPopup(
          '<b>' + h.name + '</b><br>' + h.region + '<br>~' + h.price.toLocaleString('de-DE') + ' € / Familie<br>' +
          '<a href="' + h.url + '" target="_blank" rel="noopener">bei CHECK24 ansehen ↗</a>'
        );
        pts.push([h.lat, h.lng]);
      });
      var bounds = L.latLngBounds(pts);
      map.fitBounds(bounds, { padding: [30, 30] });
      window.__maps[id] = { map: map, bounds: bounds };
    }
    Array.prototype.forEach.call(document.querySelectorAll('[id^="hotels-"]'), function (el) { initHotelMap(el.id.replace('hotels-', '')); });
  </script>
</body>
</html>
