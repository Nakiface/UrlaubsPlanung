// ---- Hilfsfunktionen ---------------------------------------
const fmt = (n) => n.toLocaleString('de-DE');
const eur = (n) => '~' + n.toLocaleString('de-DE') + ' €';
const gmaps = (q) => 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(q);
// Wärme-Klasse fuer Farbgebung (Lufttemperatur)
const warmClass = (t) => (t >= 27 ? 'hot' : t >= 23 ? 'warm' : 'mild');

// Klima-Visualisierung: Balken fuer Luft- & Wassertemperatur + Sonne/Regen
function weatherSVG(d) {
  const W = 460, H = 178, padL = 96, padR = 56, padT = 22, padB = 22;
  const innerW = W - padL - padR;
  const scaleMax = 32; // Grad-Skala
  const rows = [
    { lbl: 'Luft', val: d.airTemp, color: 'var(--temp-air)' },
    { lbl: 'Wasser', val: d.waterTemp, color: 'var(--temp-water)' },
  ];
  const rowH = 30, gap = 20, top = padT + 6;
  let svg = '<svg class="weather" viewBox="0 0 ' + W + ' ' + H + '" role="img" aria-label="Klima ' + d.name + ' im Oktober">';
  // Skalenlinien
  [10, 20, 30].forEach((g) => {
    const xx = padL + (g / scaleMax) * innerW;
    svg += '<line class="grid" x1="' + xx + '" y1="' + (top - 6) + '" x2="' + xx + '" y2="' + (top + rows.length * (rowH + gap) - gap + 6) + '"/>';
    svg += '<text class="ax" x="' + xx + '" y="' + (top + rows.length * (rowH + gap) - gap + 20) + '" text-anchor="middle">' + g + '°</text>';
  });
  rows.forEach((r, i) => {
    const y = top + i * (rowH + gap);
    const w = Math.max(6, (r.val / scaleMax) * innerW);
    svg += '<text class="rlbl" x="' + (padL - 12) + '" y="' + (y + rowH / 2 + 4) + '" text-anchor="end">' + r.lbl + '</text>';
    svg += '<rect x="' + padL + '" y="' + y + '" width="' + innerW + '" height="' + rowH + '" rx="7" fill="#eef3f8"/>';
    svg += '<rect x="' + padL + '" y="' + y + '" width="' + w + '" height="' + rowH + '" rx="7" fill="' + r.color + '"/>';
    svg += '<text class="val" x="' + (padL + w + 8) + '" y="' + (y + rowH / 2 + 4) + '">' + r.val + ' °C</text>';
  });
  svg += '</svg>';
  return svg;
}

// Übersicht: Vergleichsdaten fuer das Balkendiagramm
const CHART = destinations.map((d) => ({
  name: d.name,
  priceAI: d.priceAI, priceSV: d.priceSV,
  airTemp: d.airTemp, waterTemp: d.waterTemp,
  sunHours: d.sunHours, rainDays: d.rainDays, flightTime: d.flightTime,
}));
